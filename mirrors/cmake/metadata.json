{
  "type": "bundle", "version": 1, "env": [
    {
      "key": "PATH",
      "type": "path",
      "required": true,
      "value": "${installPath}/bin"
    },
    {
      "key": "MANPATH",
      "type": "path",
      "required": false,
      "value": "${installPath}/man",
      "visibility": "public"
    }
  ],
  "entrypoints": [
    {
      "name": "cmake",
      "target": "${installPath}/bin/cmake"
    },
    {
      "name": "cmake-gui",
      "target": "${installPath}/bin/cmake-gui"
    },
    {
      "name": "cpack",
      "target": "${installPath}/bin/cpack"
    },
    {
      "name": "ctest",
      "target": "${installPath}/bin/ctest"
    }
  ]
}
