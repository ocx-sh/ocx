{
  "type": "bundle",
  "version": 1,
  "env": [
    {
      "key": "PATH",
      "type": "path",
      "required": true,
      "value": "${installPath}/CMake.app/Contents/bin",
      "visibility": "public"
    },
    {
      "key": "MANPATH",
      "type": "path",
      "required": false,
      "value": "${installPath}/CMake.app/Contents/man",
      "visibility": "public"
    }
  ],
  "entrypoints": [
    {
      "name": "cmake"
    },
    {
      "name": "cmake-gui"
    },
    {
      "name": "cpack"
    },
    {
      "name": "ctest"
    }
  ]
}
