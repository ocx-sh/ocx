{
  "type": "bundle",
  "version": 1,
  "env": [
    {
      "key": "PATH",
      "type": "path",
      "required": true,
      "value": "${installPath}/CMake.app/Contents/bin",
      "visibility": "public"
    },
    {
      "key": "MANPATH",
      "type": "path",
      "required": false,
      "value": "${installPath}/CMake.app/Contents/man",
      "visibility": "public"
    }
  ],
  "entrypoints": {
    "cmake": {},
    "cmake-gui": {},
    "cpack": {},
    "ctest": {}
  }
}
