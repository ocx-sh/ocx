{
  "type": "bundle",
  "version": 1,
  "env": [
    {
      "key": "PATH",
      "type": "path",
      "required": true,
      "value": "${installPath}/bin",
      "visibility": "public"
    },
    {
      "key": "HELLO_HOME",
      "type": "constant",
      "value": "${installPath}",
      "visibility": "public"
    }
  ],
  "entrypoints": [
    { "name": "hello", "target": "${installPath}/bin/hello" }
  ]
}
