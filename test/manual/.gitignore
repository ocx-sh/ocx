# Disposable OCX_HOME created by scripts/env.sh.
.ocx-home/

# Per-package bundle output directory written by bootstrap.sh.
packages/*/out/

# Rendered metadata.json for every package — bootstrap.sh produces it from
# `metadata.in.json` (with `@@KEY@@` substitutions for templated packages,
# or as a plain copy for packages with no variables). The source of truth
# is `metadata.in.json`, which is committed.
packages/*/metadata.json

# Generated `bin/` payload trees scaffolded by scripts/_lib.sh
# (scaffold_payloads). The committed multi-layer-app layer-base/layer-libs
# `.so` stubs are NOT covered by these globs.
packages/*/build/
packages/multi-layer-app/layer-app/

# Patches sub-packages — same conventions as top-level packages.
packages/patches/*/out/
packages/patches/*/build/
packages/patches/*/metadata.json
