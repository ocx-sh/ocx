{
    "task": {
        "outputTo": "terminal",
    },
    // Exclude the Rust build dir from Coverage Gutters' recursive search.
    // lcov.info lives at the workspace root, so this speeds up file discovery.
    "coverage-gutters.ignoredPathGlobs": "**/{node_modules,venv,.venv,vendor,target}/**",
    // Hide Python build artifacts from the explorer.
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/*.pyc": true,
    },
}